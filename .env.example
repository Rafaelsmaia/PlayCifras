# Supabase / Postgres (Prisma)
# Connection pooling (porta 6543, pgbouncer) — uso normal da app
DATABASE_URL=
# Conexão direta (porta 5432) — migrations (prisma migrate deploy)
DIRECT_URL=

# NextAuth / Auth.js — obrigatório em produção
# Gere um segredo: openssl rand -base64 32
AUTH_SECRET=

# URL pública da aplicação (desenvolvimento)
AUTH_URL=http://localhost:3000

# Opcional: login com Google (habilita o provedor em auth.ts)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Spotify (recomendado para fotos) — mesmo script: npx tsx scripts/fetch-artist-images.ts
# App: https://developer.spotify.com/dashboard — Client ID + Client Secret (fluxo client credentials)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm — fallback se o Spotify não achar foto
# Chave: https://www.last.fm/api/account/create
LASTFM_API_KEY=
# Opcional: imagem local quando a API não tiver foto (silhueta em public/images/artistas/silhouette.svg)
# DEFAULT_ARTIST_IMAGE=/images/artistas/silhouette.svg

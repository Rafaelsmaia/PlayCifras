// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Genre {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  songs Song[]

  @@map("genres")
}

model Artist {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  bio       String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  songs Song[]

  @@map("artists")
}

model Song {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  artistId   String
  genreId    String?
  key        String?
  tempo      Int?
  difficulty String?
  content    String
  tags       String
  views      Int      @default(0)
  likes      Int      @default(0)
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  artist    Artist         @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre     Genre?         @relation(fields: [genreId], references: [id], onDelete: SetNull)
  chords    Chord[]
  favorites UserFavorite[]

  @@map("songs")
}

model Chord {
  id           String   @id @default(cuid())
  name         String
  songId       String
  frets        String
  fingering    String
  barre        Boolean  @default(false)
  barreFret    Int?
  openStrings  String
  mutedStrings String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@map("chords")
}

/** Posições padrão de acordes (violão/guitarra) — um registo por nome + instrumento. */
model ChordDictionary {
  id          String   @id @default(cuid())
  name        String
  instrument  String   @default("guitar")
  frets       String
  fingering   String
  barre       Boolean  @default(false)
  barreFret   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, instrument])
  @@map("chord_dictionary")
}

// NextAuth + dados do app (favoritos)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  favorites UserFavorite[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserFavorite {
  id     String @id @default(cuid())
  userId String
  songId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
  @@map("user_favorites")
}
